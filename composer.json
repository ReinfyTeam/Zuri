{
    "name": "reinfyteam/zuri",
    "type": "project",
    "description": "Build helpers for Zuri pharynx workflows",
    "license": "LGPL-3.0-or-later",
    "scripts": {
        "build": [
            "rm -f pharynx.phar LibVapmPMMP.zip Zuri.phar build_info.json",
            "rm -rf LibVapmPMMP-2.5.6",
            "curl -fsSL https://github.com/SOF3/pharynx/releases/latest/download/pharynx.phar -o pharynx.phar",
            "curl -fsSL https://github.com/VennDev/LibVapmPMMP/archive/refs/tags/2.5.6.zip -o LibVapmPMMP.zip",
            "unzip -q -o LibVapmPMMP.zip",
            "php pharynx.phar -i . -a LibVapmPMMP-2.5.6 -p Zuri.phar",
            "printf '{\n  \"artifact\": \"Zuri.phar\",\n  \"virion\": \"LibVapmPMMP-2.5.6\"\n}\n' > build_info.json"
        ],
        "build-source": [
            "rm -f pharynx.phar LibVapmPMMP.zip",
            "rm -rf LibVapmPMMP-2.5.6 output",
            "curl -fsSL https://github.com/SOF3/pharynx/releases/latest/download/pharynx.phar -o pharynx.phar",
            "curl -fsSL https://github.com/VennDev/LibVapmPMMP/archive/refs/tags/2.5.6.zip -o LibVapmPMMP.zip",
            "unzip -q -o LibVapmPMMP.zip",
            "php pharynx.phar -i . -a LibVapmPMMP-2.5.6 -o output"
        ]
    }
}
